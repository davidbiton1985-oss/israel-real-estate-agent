<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Facebook reader watchdog: every 30 min, WhatsApp a nudge if the #re-agent
  notifications tab hasn't delivered for 45+ minutes during waking hours
  (see ops/fb-watchdog.ts). Companion to com.david.yad2-watchdog.

  Install:
    cp ops/com.david.fb-watchdog.plist ~/Library/LaunchAgents/
    launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/com.david.fb-watchdog.plist
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.david.fb-watchdog</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-lc</string>
    <string>cd /Users/david/israel-real-estate-agent &amp;&amp; npx tsx ops/fb-watchdog.ts</string>
  </array>
  <key>StartInterval</key>
  <integer>1800</integer>
  <key>RunAtLoad</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/Users/david/Library/Logs/re-agent-watchdog.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/david/Library/Logs/re-agent-watchdog.log</string>
</dict>
</plist>
