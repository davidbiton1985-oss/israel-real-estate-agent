<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  RE-Agent auto-start (macOS LaunchAgent).

  Starts the Next.js server on login and restarts it if it crashes, so the
  Yad2/Facebook browser watchers always have localhost:3000 to deliver to.

  Install (one-time):
    cp ops/com.david.re-agent.plist ~/Library/LaunchAgents/
    launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/com.david.re-agent.plist

  Manage:
    launchctl kickstart -k gui/$(id -u)/com.david.re-agent   # restart now
    launchctl bootout gui/$(id -u)/com.david.re-agent        # stop + disable
    tail -f ~/Library/Logs/re-agent.log                      # logs
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.david.re-agent</string>

  <!-- zsh -lc loads the login PATH (homebrew node) before running npm -->
  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-lc</string>
    <string>cd /Users/david/israel-real-estate-agent &amp;&amp; exec npm run dev</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <!-- restart automatically if the process dies -->
  <key>KeepAlive</key>
  <true/>

  <!-- don't crash-loop faster than every 15s (e.g. if the port is briefly taken) -->
  <key>ThrottleInterval</key>
  <integer>15</integer>

  <key>StandardOutPath</key>
  <string>/Users/david/Library/Logs/re-agent.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/david/Library/Logs/re-agent.log</string>
</dict>
</plist>
