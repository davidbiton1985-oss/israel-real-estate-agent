generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id                 String   @id @default(cuid())
  name               String
  dealType           String // RENT | SALE
  cities             String // comma-separated
  neighborhoods      String? // comma-separated
  streets            String? // comma-separated
  priceMin           Int?
  priceMax           Int
  roomsMin           Float?
  roomsMax           Float?
  sizeMinSqm         Int?
  propertyType       String? // APARTMENT | HOUSE | GARDEN_APT | PENTHOUSE | ANY
  entryBy            String? // ISO date the user needs entry by (optional)
  // feature prefs: REQUIRED | PREFERRED | INDIFFERENT
  balcony            String   @default("INDIFFERENT")
  parking            String   @default("INDIFFERENT")
  elevator           String   @default("INDIFFERENT")
  mamad              String   @default("INDIFFERENT")
  // brokerage filters (first-class)
  brokerStatusPref   String   @default("any") // any | private_only | broker_only | private_preferred_broker_allowed_if_strong_match | unknown_allowed
  brokerFeePref      String   @default("unknown_allowed") // no_fee_only | fee_allowed | unknown_allowed | max_fee_if_known
  maxFeeIfKnown      Int?
  whatsappThreshold  Int      @default(80)
  dashboardThreshold Int      @default(60)
  // Re-alert once a listing that already fired an alert later drops in price
  // or changes materially (rooms/balcony/parking/broker status). Without this,
  // a listing only ever alerts once per profile.
  priceDropReAlert   Boolean  @default(true)
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  matches            Match[]
}

model Listing {
  id              String   @id @default(cuid())
  source          String // YAD2 | FACEBOOK | WHATSAPP | MANUAL | URL | DEMO
  url             String?
  yad2ListingId   String?
  rawText         String
  dealType        String? // RENT | SALE
  city            String?
  neighborhood    String?
  street          String?
  price           Int?
  rooms           Float?
  sizeSqm         Int?
  floor           Int?
  totalFloors     Int?
  balcony         Boolean?
  parking         Boolean?
  elevator        Boolean?
  mamad           Boolean?
  storage         Boolean?
  garden          Boolean?
  condition       String? // RENOVATED | NEW
  furnished       String? // FURNISHED | PARTIAL | UNFURNISHED
  propertyType    String?
  entryImmediate  Boolean?
  entryFlexible   Boolean?
  entryDate       String?
  arnonaMonthly   Int?
  vaadMonthly     Int?
  brokerStatus    String   @default("UNKNOWN") // PRIVATE | BROKER | UNKNOWN
  brokerConfidence String  @default("low") // high | medium | low
  brokerEvidence  String?
  brokerFeeStatus String   @default("UNKNOWN") // NONE | EXISTS | UNKNOWN
  brokerFeeText   String?
  // The decide→act loop (UX council Wave 2):
  imageUrl        String? // apartment photo: /uploads/<id>.jpg once localized, else the source CDN url
  phone           String? // lister phone extracted from rawText, E.164 (+972…)
  userStatus      String   @default("NEW") // NEW | CONTACTED | VIEWING | DISMISSED | WON
  userNote        String? // David's pursuit note ("callback after 18:00")
  viewingAt       DateTime?
  // Facebook source metadata (set when source=FACEBOOK, from notification
  // emails or browser capture): which surface the post came from and from whom.
  fbSurface       String? // GROUP | PAGE | PROFILE | PUBLIC_POST | SHARED | MARKETPLACE | UNKNOWN
  fbSourceName    String? // group/page name if known
  fbAuthor        String? // post author if known
  fingerprint     String
  isDuplicateOf   String?
  // JSON array of {amount, seenAt} — appended whenever a re-paste of the same
  // fingerprint (Yad2 ID / URL / content) arrives with a different price.
  priceHistory    String   @default("[]")
  scanned         Boolean  @default(false) // processed by matching pipeline
  // Free-text notes from manual real-world QA, e.g. "price parsed wrong",
  // "should not be duplicate" — not used by any scoring/matching logic.
  qaNotes         String?
  createdAt       DateTime @default(now())
  matches         Match[]
}

model Match {
  id                String   @id @default(cuid())
  profileId         String
  listingId         String
  profile           Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  listing           Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  score             Int
  status            String // strong_match | possible_match | weak_match | rejected
  reasonsPositive   String // JSON string[]
  reasonsNegative   String // JSON string[]
  missingFields     String // JSON string[]
  redFlags          String // JSON string[]
  recommendedAction String
  alerted           Boolean  @default(false)
  alertChannel      String? // whatsapp | console
  // Snapshot of state at the moment the last alert fired for this (profile, listing)
  // pair — used to detect price drops / material changes on re-scan without
  // re-alerting on unchanged repeats.
  lastAlertedPrice    Int?
  lastAlertedSnapshot String? // JSON: {rooms, balcony, parking, brokerStatus}
  alerts              Alert[]
  createdAt           DateTime @default(now())

  @@unique([profileId, listingId])
}

// One row per automatic source (e.g. "EMAIL"), upserted on every poll tick —
// powers the dashboard's source-health panel.
model SourceHealth {
  id                String    @id @default(cuid())
  source            String    @unique // EMAIL (more connectors later)
  enabled           Boolean   @default(true)
  lastCheckAt       DateTime?
  lastSuccessAt     DateTime?
  lastError         String?
  consecutiveErrors Int       @default(0)
  lastItemsFound    Int       @default(0) // items seen in the most recent poll
  lastNewListings   Int       @default(0) // of those, how many were new (not updates/dups)
  totalIngested     Int       @default(0) // lifetime counter
  updatedAt         DateTime  @updatedAt
  createdAt         DateTime  @default(now())
}

model Alert {
  id        String    @id @default(cuid())
  matchId   String?
  match     Match?    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  kind      String // MATCH_ALERT | TEST_ALERT
  channel   String // whatsapp | console | none
  status    String // QUEUED | SENDING | SENT | FAILED | SUPPRESSED
  reason    String? // NEW_MATCH | PRICE_DROP | MATERIAL_CHANGE | DUPLICATE_SUPPRESSED | NO_CHANGE_SUPPRESSED | TEST
  message   String
  error     String?
  sentAt    DateTime?
  createdAt DateTime  @default(now())
}

// A device subscribed to Web Push (the installed PWA). One row per device;
// dead endpoints (410 Gone) are pruned automatically on send.
model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
}
