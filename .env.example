# SQLite database (local file)
DATABASE_URL="file:./dev.db"

# --- Telegram (PREFERRED alert channel — no 24h delivery window like WhatsApp) ---
# Setup (~2 minutes):
#   1. In Telegram, message @BotFather → /newbot → follow prompts → copy the bot token.
#   2. Open your new bot and send it any message (e.g. "hi") so it has a chat to reply to.
#   3. Run: npm run telegram:setup   — it reads the token, finds your chat id, and (once
#      both are set) sends a test. Paste the chat id it prints into TELEGRAM_CHAT_ID.
# When both are set, ALL alerts (matches, digests, heartbeat, watchdogs) go via Telegram;
# WhatsApp/console below stay as fallback.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# --- WhatsApp via Twilio (optional — console fallback used when any var below is empty) ---
# All four vars below must be set for real WhatsApp delivery to be attempted.
#
# How to test with the Twilio Sandbox (free, ~2 minutes):
#   1. Sign up at https://console.twilio.com and open Messaging → Try it out → Send a WhatsApp message.
#   2. Copy your Account SID and Auth Token from the console dashboard into the two vars below.
#   3. The sandbox "From" number is shown on that page — it's usually whatsapp:+14155238886 (default below).
#   4. From the phone you want alerts on, send the sandbox's "join <code-word>" message to that number on WhatsApp.
#      (Sandbox sessions expire after ~72h of inactivity — rejoin if alerts stop arriving.)
#   5. Set ALERT_WHATSAPP_TO to your own phone in the same whatsapp:+<countrycode><number> format.
#   6. Run the app and click "Send test alert" on the dashboard — it shows SENT/FAILED and any Twilio error inline.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
ALERT_WHATSAPP_TO="whatsapp:+972500000000"

# --- Automatic ingestion: email alerts via IMAP (the main automatic source) ---
# The app polls this inbox every SCAN_INTERVAL_MIN minutes for saved-search
# alert emails (Yad2 alerts, other portals, broker mailing lists) and pushes
# strong matches to WhatsApp automatically. Setup (Gmail example):
#   1. Create/choose a Gmail address to receive listing alerts.
#   2. Google Account → Security → 2-Step Verification → App passwords →
#      create one for "Mail"; use it as IMAP_PASS (NOT your real password).
#   3. On Yad2: save your searches and enable email alerts (immediate, not
#      daily digest) to this address. Same for any other portal/broker list.
#   4. Facebook monitoring rides the same inbox: turn on per-group "All posts"
#      notifications + email notifications on Facebook, and its notification
#      emails (from facebookmail.com) are ingested with group/author metadata.
#   5. Optional: EMAIL_ALLOWED_SENDERS limits which senders are ingested
#      (comma-separated substrings matched against the From header);
#      leave empty to ingest every unseen email in the folder.
IMAP_HOST="imap.gmail.com"
IMAP_PORT="993"
IMAP_SECURE="true"
IMAP_USER=""
IMAP_PASS=""
IMAP_FOLDER="INBOX"
EMAIL_ALLOWED_SENDERS="yad2,facebookmail"

# Watcher poll interval (minutes)
SCAN_INTERVAL_MIN="5"

# --- External dead-man's switch (optional) ---
# Create a free check at https://healthchecks.io, paste its ping URL here.
# The scheduler pings it each tick ONLY when both browser sensors are fresh, so
# the external service alarms you (independent of Twilio and the Mac) whenever
# coverage lapses — a stale sensor, a wedged scheduler, or a dead Mac.
HEALTHCHECK_URL=""
